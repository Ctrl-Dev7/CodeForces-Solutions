#include<bits/stdc++.h>
using namespace std;
 
int main(){
    int t;
    cin >> t;
 
    while(t--){
        int n, k;
        cin >> n >> k;
        int arr[n];
 
        for(int i=0; i<n; i++){
            cin >> arr[i];
        }
 
        bool kPresent = false;
        
        for(int i=0; i<n; i++){
            if(arr[i]==k){  
                kPresent = true;
                break;
            }else{
                kPresent = false;
            }
        }
 
        if(kPresent == true){
            cout << "YES" << endl;
        }else{
            cout << "NO" << endl;
        }
    }
 
    return 0;
}