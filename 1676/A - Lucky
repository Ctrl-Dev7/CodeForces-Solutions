#include<bits/stdc++.h>
using namespace std;
 
int main(){
    int t;
    cin >> t;
 
    while(t--){
        string s;
        cin >> s;
        int leftSum =0;
        int rightSum =0;
        for(int i=0; i<3; i++){
            leftSum += s[i];
        }
        for(int i=3; i<s.length(); i++){
            rightSum += s[i];
        }
 
        if(leftSum == rightSum){
            cout << "YES" << endl;
        }else{
            cout << "NO" << endl;
        }
    }
 
    return 0;
}